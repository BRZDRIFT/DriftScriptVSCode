{
    "name": "driftscript-language",
    "displayName": "DriftScript",
    "description": "DriftScript language support.. The official scripting language of Drift Wars!",
    "version": "0.0.27",
    "license": "MIT",
    "icon": "images/icon.png",
    "publisher": "BRZDRIFT",
    "repository": {
        "type": "git",
        "url": "https://github.com/BRZDRIFT/DriftScriptVSCode.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": ["Programming Languages"],
    "main": "./src/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "driftscript",
                "aliases": ["DriftScript", "driftscript"],
                "extensions": [".DriftScript"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "driftscript",
                "scopeName": "source.driftscript",
                "path": "./syntaxes/driftscript.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "driftscript.openInDriftDocs",
                "title": "Open in DriftDocs"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "driftscript.openInDriftDocs",
                    "when": "resourceLangId == driftscript",
                    "group": "navigation"
                }
            ]
        }
    }
}
